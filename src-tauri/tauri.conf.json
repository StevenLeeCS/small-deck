{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Small Deck",
  "version": "0.1.0",
  "identifier": "com.xtia.xpad.smalldeck",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Small Deck",
        "width": 720,
        "height": 640,
        "minWidth": 560,
        "minHeight": 480,
        "resizable": true,
        "visible": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: asset: http://asset.localhost; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'; frame-src https://xtiaconfiger.com"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
